JAVA_BIN=java
JAVA_OPTS=-Xms256m -Xmx512m

LOGGUARDIAN_MODE=gui
SPRING_MAIN_WEB_APPLICATION_TYPE=reactive
SERVER_PORT=9091

SPRING_AI_CHAT_CLIENT_ENABLED=false
LOGGUARDIAN_AI_ENABLED=false
LOGGUARDIAN_EMAIL_ENABLED=false

MONGODB_URI=mongodb://localhost:27017/logguardian
MONGODB_DATABASE=logguardian

REDIS_HOST=localhost
REDIS_PORT=6379

MAIL_HOST=localhost
MAIL_PORT=2525

# Optional extra arguments appended after the jar path.
SPRING_ARGS=
